{
  "name": "worklink-e2e-tests",
  "version": "1.0.0",
  "description": "Selenium E2E Tests for WorkLink Live GitHub Pages Deployment — 470+ Test Cases",
  "private": true,
  "scripts": {
    "test": "jest --json --outputFile=jest-results.json --forceExit --runInBand",
    "report": "node utils/reportGenerator.js",
    "test:report": "npm test; node utils/reportGenerator.js",
    "test:headed": "HEADLESS=false jest --json --outputFile=jest-results.json --forceExit --runInBand"
  },
  "dependencies": {
    "selenium-webdriver": "^4.21.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-html-reporter": "^3.10.2",
    "exceljs": "^4.4.0",
    "fs-extra": "^11.2.0"
  }
}

